<%- include('html_above') %>
<%_ const headerComponent=data.headerComponent; _%>
<%_ if (headerComponent) { _%>
  <%- include(headerComponent.template, { header: headerComponent.data, getHref, getSrc }) %>
<%_ } else { _%>
  <%- include('comp_header') %>
<%_ } _%>
<%- include('comp_breadcrumb') %>

  <h1 class="f3 text-bold text-center">
    <%= data.title || 'Cities Sitemap' %>
  </h1>
  <%_ const linksComponent=data.linksComponent; _%>
  <%_ if (linksComponent && linksComponent.data && linksComponent.data.length) { _%>
    <section class="section grid grid-xs-1 fixed">
      <h2 class="f4 text-bold">Cities</h2>
      <%- include(linksComponent.template, { links: linksComponent.data, getHref, getSrc }) %>
    </section>
  <%_ } _%>
<%_ const footerComponent=data.footerComponent; _%>
<%_ if (footerComponent) { _%>
  <%- include(footerComponent.template, { footer: footerComponent.data, getHref, getSrc }) %>
<%_ } else { _%>
  <%- include('html_footer') %>
<%_ } _%>
<%- include('html_below') %>